{
  "name": "Example: Update MediaWiki Page with Template",
  "nodes": [
    {
      "parameters": {},
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "pageTitle": "Test Page",
        "templateName": "Infobox",
        "position": "top",
        "templateVariables": {
          "variable": [
            {
              "name": "title",
              "value": "Example Article"
            },
            {
              "name": "author",
              "value": "John Doe"
            },
            {
              "name": "date",
              "value": "={{ $now.toFormat('yyyy-MM-dd') }}"
            },
            {
              "name": "status",
              "value": "Published"
            }
          ]
        },
        "editSummary": "Updated via n8n automation"
      },
      "name": "MediaWiki Template",
      "type": "n8n-nodes-mediawiki.mediaWikiCreateOrUpdateTemplate",
      "typeVersion": 1,
      "position": [450, 300],
      "credentials": {
        "mediaWikiApi": {
          "id": "1",
          "name": "MediaWiki API account"
        }
      }
    }
  ],
  "connections": {
    "Manual Trigger": {
      "main": [
        [
          {
            "node": "MediaWiki Template",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
