{
  "name": "n8n-nodes-mediawiki",
  "version": "0.1.0",
  "description": "n8n nodes for interacting with MediaWiki",
  "license": "MIT",
  "homepage": "https://github.com/neayi/n8n_mediawiki",
  "author": {
    "name": "Bertrand Gorge",
    "email": "bertrand.gorge@neayi.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neayi/n8n_mediawiki.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lintfix": "eslint . --fix",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/MediaWikiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/MediaWiki/MediaWikiCreateOrUpdateTemplate.node.js",
      "dist/nodes/MediaWiki/MediaWikiAddPage.node.js",
      "dist/nodes/MediaWiki/MediaWikiUploadFile.node.js",
      "dist/nodes/MediaWiki/MediaWikiGetTemplateData.node.js",
      "dist/nodes/MediaWiki/MediaWikiSemanticQuery.node.js"
    ]
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "mediawiki",
    "wiki"
  ],
  "devDependencies": {
    "@types/node": "^18.16.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "eslint": "^8.40.0",
    "eslint-plugin-n8n-nodes-base": "^1.11.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.0.0",
    "prettier": "^2.8.8",
    "typescript": "^5.0.4"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "form-data": "^4.0.5"
  }
}
