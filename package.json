{
  "name": "@neayi/n8n-nodes-mediawiki",
  "version": "0.1.1",
  "description": "n8n nodes for interacting with MediaWiki",
  "license": "MIT",
  "homepage": "https://github.com/neayi/n8n_mediawiki",
  "author": {
    "name": "Bertrand Gorge",
    "email": "bertrand.gorge@neayi.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neayi/n8n_mediawiki.git"
  },
  "bugs": {
    "url": "https://github.com/neayi/n8n_mediawiki/issues"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lintfix": "eslint . --fix",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/MediaWikiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/MediaWiki/MediaWikiCreateOrUpdateTemplate.node.js",
      "dist/nodes/MediaWiki/MediaWikiAddPage.node.js",
      "dist/nodes/MediaWiki/MediaWikiUploadFile.node.js",
      "dist/nodes/MediaWiki/MediaWikiGetTemplateData.node.js",
      "dist/nodes/MediaWiki/MediaWikiSemanticQuery.node.js",
      "dist/nodes/MediaWiki/MediaWikiGetPageContent.node.js"
    ]
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "mediawiki",
    "wiki"
  ],
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "eslint-plugin-n8n-nodes-base": "^1.16.6",
    "globals": "^17.5.0",
    "gulp": "^5.0.1",
    "n8n-workflow": "^2.16.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "form-data": "^4.0.5"
  }
}
